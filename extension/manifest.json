{
  "manifest_version": 2,
  "name": "AI Chat Logbook",
  "version": "0.1.0",
  "description": "Capture allowed AI chat pages as Markdown logs for later context handoff.",
  "applications": {
    "gecko": {
      "id": "ai-chat-logbook@zeittresor.local",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "downloads",
    "nativeMessaging",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "shared/defaults.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "shared/defaults.js",
        "shared/i18n.js",
        "content_script.js"
      ],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_title": "AI Chat Logbook",
    "default_popup": "popup/popup.html"
  }
}
